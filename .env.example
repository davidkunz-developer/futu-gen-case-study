# FutuGen - Audio Streaming Pipeline Environment Configuration

# OpenAI API Klíč pro modul klasifikátoru a transkripce (Povinné)
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace token pro přístup k pyannote.audio diarization modelům (Povinné pro Model 2)
# HF_TOKEN=your_huggingface_token_here

# Vstupní režim: "live" = mikrofon, "mock" = mock.wav soubor (výchozí: live)
INPUT_MODE=live

# Ovládání Diarizace (true/false) - výchozí: true
ENABLE_DIARIZATION=true
